# Ignore bundle-local data contents, but keep .osim files in models/ tracked
models/**/data/**
!models/**/data/
!models/**/data/**/
!models/**/data/.gitkeep
!models/**/data/**/.gitkeep

# Ignore plugin and result contents, but keep the folders tracked
plugins/*
results/*

# Keep the folders themselves in the repository
!models/.gitkeep
!plugins/.gitkeep

# OpenSim log (can exceed GitHub 100 MB limit)
opensim.log

# Local state for the most recently used simulator setup XML
.simulator_last_setup.json
